<footer class="site-footer">
  <div class="container">
    <div class="footer__grid">

      <div class="footer__col footer__brand">
        <a class="brand" href="/" aria-label="{{ site.legalName }} home">
          <img class="brand__logo" src="/assets/logo.png" width="300" height="150" alt="{{ site.legalName }}">
        </a>
        <p class="footer__about">{{ site.tagline }}. Trusted by manufacturers, industrial plants and export buyers.</p>
      </div>

      <div class="footer__col">
        <h3>Products</h3>
        <ul>
          <li><a href="/products/lead-based-stabilizers/">Lead Based Stabilizers</a></li>
          <li><a href="/products/calcium-zinc-stabilizers/">Calcium-Zinc Stabilizers</a></li>
          <li><a href="/products/metallic-stearates/">Metallic Stearates</a></li>
          <li><a href="/applications/">Applications</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h3>Company</h3>
        <ul>
          <li><a href="/about/">About Us</a></li>
          <li><a href="/products/">Product Range</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="/contact/">Request a Quote</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h3>Get in Touch</h3>
        <ul class="footer__contact">
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{{ site.contact.address.locality }}, {{ site.contact.address.region }}, {{ site.contact.address.country }}</span>
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3-8.6A2 2 0 014.1 2H7a2 2 0 012 1.7c.1.9.4 1.8.7 2.7a2 2 0 01-.5 2.1L8.1 9.6a16 16 0 006 6l1.1-1.1a2 2 0 012.1-.5c.9.3 1.8.6 2.7.7A2 2 0 0122 16.9z"/></svg>
            <a href="{{ site.contact.phoneHref }}">{{ site.contact.phone }}</a>
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="M22 6l-10 7L2 6"/></svg>
            <a href="{{ site.contact.emailHref }}">{{ site.contact.email }}</a>
          </li>
        </ul>
      </div>

    </div>

    <div class="footer__bottom">
      <p>&copy; {{ site.buildYear }} {{ site.legalName }}. All rights reserved.</p>
      <p>Manufacturer &amp; Supplier of PVC Stabilizers &amp; Additives</p>
    </div>
  </div>
</footer>
