<span id="top"></span>
<header class="site-header{% if heroHeader %} site-header--overlay{% endif %}" data-header>
  {# Top utility strip — established-manufacturer pattern (desktop only) #}
  <div class="utility-bar">
    <div class="container utility-bar__inner">
      <div class="utility-bar__group">
        <a href="{{ site.contact.phoneHref }}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3-8.6A2 2 0 014.1 2H7a2 2 0 012 1.7c.1.9.4 1.8.7 2.7a2 2 0 01-.5 2.1L8.1 9.6a16 16 0 006 6l1.1-1.1a2 2 0 012.1-.5c.9.3 1.8.6 2.7.7A2 2 0 0122 16.9z"/></svg>
          {{ site.contact.phone }}
        </a>
        <a href="{{ site.contact.emailHref }}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="M22 6l-10 7L2 6"/></svg>
          {{ site.contact.email }}
        </a>
      </div>
      <div class="utility-bar__group">
        <span class="utility-bar__note">High Quality Manufacturer of PVC Stabilizer since {{ site.facts.founded }}</span>
      </div>
    </div>
  </div>
  <div class="container site-header__inner">

    <a class="brand" href="/" aria-label="{{ site.legalName }} home">
      <img class="brand__logo" src="/assets/logo.png" width="320" height="58" alt="{{ site.legalName }}">
    </a>

    <nav class="nav" id="primary-nav" aria-label="Primary" data-nav>
      <button class="nav__close" type="button" aria-label="Close menu" data-nav-close>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <ul class="nav__list">
        {% for item in nav.primary %}
        {% if item.children %}
        <li class="nav__item nav__item--has-children">
          <a class="nav__link" href="{{ item.href }}" aria-haspopup="true"
             {% if page.url == item.href %}aria-current="page"{% endif %}>{{ item.label }}
            {% if not item.hideCaret %}<svg class="nav__caret" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>{% endif %}
          </a>
          <button class="nav__subtoggle" type="button" aria-expanded="false" aria-label="Toggle {{ item.label }} submenu" data-subtoggle>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <ul class="nav__dropdown">
            {% for child in item.children %}
            <li><a class="nav__dropdown-link" href="{{ child.href }}">{{ child.label }}</a></li>
            {% endfor %}
          </ul>
        </li>
        {% else %}
        <li class="nav__item">
          <a class="nav__link" href="{{ item.href }}"
             {% if page.url == item.href %}aria-current="page"{% endif %}>{{ item.label }}</a>
        </li>
        {% endif %}
        {% endfor %}
        {# Quote CTA lives inside the drawer on mobile (hidden on desktop) #}
        <li class="nav__item nav__cta">
          <a class="btn--quote" href="{{ site.cta.quote.href }}">{{ site.cta.quote.label }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </li>
      </ul>
    </nav>

    <div class="header-utility">
      <a class="btn--quote btn--quote-desktop" href="{{ site.cta.quote.href }}">{{ site.cta.quote.label }}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>

      <button class="nav-toggle" type="button" aria-label="Open menu" aria-controls="primary-nav" aria-expanded="false" data-nav-toggle>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>

  </div>
</header>
