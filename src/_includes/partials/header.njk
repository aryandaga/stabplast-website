<span id="top"></span>
<header class="site-header{% if heroHeader %} site-header--overlay{% endif %}" data-header>
  <div class="container site-header__inner">

    <a class="brand" href="/" aria-label="{{ site.legalName }} home">
      <svg class="brand__mark" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
        <path d="M20 4l10 5.8v11.6L20 27.2 10 21.4V9.8z" stroke-linejoin="round"/>
        <path d="M20 27.2v8.8M13 24l-6 3.5M27 24l6 3.5" stroke-linecap="round"/>
        <circle cx="20" cy="15.5" r="2.4" fill="currentColor" stroke="none"/>
      </svg>
      <span class="brand__name">Stabplast <small>Chemo Industries</small></span>
    </a>

    <button class="nav-toggle" type="button" aria-label="Open menu" aria-controls="primary-nav" aria-expanded="false" data-nav-toggle>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>

    <nav class="nav" id="primary-nav" aria-label="Primary" data-nav>
      <ul class="nav__list">
        {% for item in nav.primary %}
        <li>
          <a class="nav__link" href="{{ item.href }}"
             {% if page.url == item.href %}aria-current="page"{% endif %}>{{ item.label }}</a>
        </li>
        {% endfor %}
      </ul>
      <div class="header-actions">
        <a class="btn btn--accent btn--quote-desktop" href="{{ site.cta.quote.href }}">{{ site.cta.quote.label }}</a>
      </div>
    </nav>

  </div>
</header>
