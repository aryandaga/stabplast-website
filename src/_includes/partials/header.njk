<span id="top"></span>
<header class="site-header{% if heroHeader %} site-header--overlay{% endif %}" data-header>
  <div class="container site-header__inner">

    <a class="brand" href="/" aria-label="{{ site.legalName }} home">
      <img class="brand__logo" src="/assets/logo.png" width="300" height="150" alt="{{ site.legalName }}">
    </a>

    <nav class="nav" id="primary-nav" aria-label="Primary" data-nav>
      <ul class="nav__list">
        {% for item in nav.primary %}
        {% if item.children %}
        <li class="nav__item nav__item--has-children">
          <a class="nav__link" href="{{ item.href }}" aria-haspopup="true"
             {% if page.url == item.href %}aria-current="page"{% endif %}>{{ item.label }}
            <svg class="nav__caret" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </a>
          <ul class="nav__dropdown">
            {% for child in item.children %}
            <li><a class="nav__dropdown-link" href="{{ child.href }}">{{ child.label }}</a></li>
            {% endfor %}
          </ul>
        </li>
        {% else %}
        <li class="nav__item">
          <a class="nav__link" href="{{ item.href }}"
             {% if page.url == item.href %}aria-current="page"{% endif %}>{{ item.label }}</a>
        </li>
        {% endif %}
        {% endfor %}
      </ul>
    </nav>

    <div class="header-utility">
      <a class="header-phone" href="{{ site.contact.phoneHref }}" aria-label="Call us on {{ site.contact.phone }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3-8.6A2 2 0 014.1 2H7a2 2 0 012 1.7c.1.9.4 1.8.7 2.7a2 2 0 01-.5 2.1L8.1 9.6a16 16 0 006 6l1.1-1.1a2 2 0 012.1-.5c.9.3 1.8.6 2.7.7A2 2 0 0122 16.9z"/></svg>
        <span class="header-phone__num">{{ site.contact.phone }}</span>
      </a>

      <a class="btn btn--accent btn--quote-desktop" href="{{ site.cta.quote.href }}">{{ site.cta.quote.label }}</a>

      <button class="nav-toggle" type="button" aria-label="Open menu" aria-controls="primary-nav" aria-expanded="false" data-nav-toggle>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>

  </div>
</header>
