---
layout: layouts/base.njk
---
{#
  Article layout — wraps markdown articles from src/articles/.
  Front matter contract: title, description, date, image, imageAlt.
  JSON-LD lives in-body (11ty layout chaining has no head block).
#}
<section class="page-hero">
  <div class="container page-hero__inner">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li class="sep" aria-hidden="true">/</li>
        <li><a href="/articles/">Technical Articles</a></li>
        <li class="sep" aria-hidden="true">/</li>
        <li aria-current="page">{{ title }}</li>
      </ol>
    </nav>
    <h1>{{ title }}</h1>
    <p>{{ description }}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <article class="prose">
      <p class="article-meta">Published {{ page.date.toLocaleDateString("en-IN", { year: "numeric", month: "long", day: "numeric" }) }} · Stabplast Technical Team</p>
      {{ content | safe }}

      <p><a class="btn btn--accent" href="{{ site.cta.quote.href }}">Discuss your formulation with us</a></p>
    </article>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "datePublished": "{{ page.date.toISOString() }}",
  "mainEntityOfPage": "{{ page.url | absoluteUrl(site.url) }}",
  "author": { "@type": "Organization", "name": "{{ site.legalName }}" },
  "publisher": { "@type": "Organization", "name": "{{ site.legalName }}", "url": "{{ site.url }}" }
}
</script>
