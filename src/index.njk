---
layout: layouts/base.njk
title: PVC Stabilizer Manufacturer & Supplier
description: Stabplast Chemo Industries manufactures PVC stabilizers, metallic stearates and lead compounds for pipes, profiles, cables and plastics. Request a quote today.
heroHeader: true
---

<!-- ============ HERO SLIDER ============ -->
<section class="hero-slider" data-slider aria-roledescription="carousel" aria-label="Stabplast highlights">
  <div class="hero-slider__viewport">
    {% for s in home.heroSlides %}
    <div class="hero-slide{{ ' is-active' if loop.first }}{{ ' hero-slide--light' if s.light }}" data-slide role="group" aria-roledescription="slide"
         aria-label="{{ loop.index }} of {{ home.heroSlides.length }}" {% if not loop.first %}aria-hidden="true"{% endif %}>
      <div class="hero-slide__media">
        {% image s.img, s.alt, "100vw", { widths: [800, 1280, 1920], loading: (loop.first and "eager" or "lazy"), fetchpriority: (loop.first and "high" or "") } %}
      </div>
      <div class="hero-slide__scrim" aria-hidden="true"></div>
      <div class="container hero-slide__content">
        <span class="hero-slide__eyebrow">{{ s.eyebrow }}</span>
        {# SEO: exactly one h1 per page — only the first slide's title is the h1 #}
        {% if loop.first %}<h1 class="hero-slide__title">{{ s.title }}</h1>
        {% else %}<p class="hero-slide__title">{{ s.title }}</p>{% endif %}
        <p class="hero-slide__text">{{ s.text }}</p>
        <div class="hero-slide__actions">
          {% for c in s.ctas %}
          <a class="btn {{ c.class }} btn--lg" href="{{ c.href }}">{{ c.label }}</a>
          {% endfor %}
        </div>
      </div>
    </div>
    {% endfor %}
  </div>

  <button class="hero-slider__arrow hero-slider__arrow--prev" type="button" data-prev aria-label="Previous slide">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
  </button>
  <button class="hero-slider__arrow hero-slider__arrow--next" type="button" data-next aria-label="Next slide">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg>
  </button>

  <div class="hero-slider__dots" role="tablist" aria-label="Choose slide">
    {% for s in home.heroSlides %}
    <button class="hero-slider__dot{{ ' is-active' if loop.first }}" type="button" data-dot role="tab"
            aria-selected="{{ 'true' if loop.first else 'false' }}" aria-label="Go to slide {{ loop.index }}"></button>
    {% endfor %}
  </div>
</section>

<!-- ============ STATS BAND ============ -->
<section class="stats-band" data-stats aria-label="Stabplast at a glance">
  <div class="container">
    <div class="stats-band__grid">
      {% for s in home.stats %}
      <div class="stats-band__item">
        {% if s.count %}
        <b class="stats-band__num" data-count="{{ s.count }}" data-suffix="{{ s.suffix }}">{{ s.count }}{{ s.suffix }}</b>
        {% else %}
        <b class="stats-band__num">{{ s.text }}</b>
        {% endif %}
        <span class="stats-band__label">{{ s.label }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ============ PRODUCT CATEGORIES ============ -->
<section class="section">
  <div class="container">
    <div class="section__head section__head--center">
      <h2>Our Range</h2>
      <p class="lead">A complete portfolio of PVC stabilization and lubrication chemistry.</p>
    </div>
    <div class="grid grid--4 cards-compact">
      {% for cat in products.categories %}
      <a class="card" href="/products/{{ cat.slug }}/">
        <div class="card__media">
          {% image cat.image, cat.name, "(max-width: 768px) 100vw, 360px" %}
        </div>
        <div class="card__body">
          <h3 class="card__title">{{ cat.name }}</h3>
          <p>{{ cat.summary }}</p>
          <span class="card__link">View category →</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ============ APPLICATIONS ============ -->
<section class="section section--alt">
  <div class="container">
    <div class="section__head section__head--center">
      <span class="eyebrow">Applications</span>
      <h2>Chemistry that performs across industries</h2>
      <p class="lead">Trusted in PVC &amp; CPVC pipes, UPVC profiles, wires &amp; cables, masterbatch and plastic products.</p>
    </div>
    <div class="grid grid--3">
      {% for app in applications %}
      {% if loop.index <= 7 %}
      {% if app.detail %}
      <a class="card app-card" href="/applications/{{ app.slug }}/">
        <div class="card__media">
          {% image app.image, app.alt, "(max-width: 768px) 100vw, 360px" %}
        </div>
        <div class="card__body">
          <h3 class="card__title">{{ app.name }}</h3>
          <p>{{ app.summary }}</p>
          <span class="card__link">Explore application →</span>
        </div>
      </a>
      {% else %}
      <article class="card app-card">
        <div class="card__media">
          {% image app.image, app.alt, "(max-width: 768px) 100vw, 360px" %}
        </div>
        <div class="card__body">
          <h3 class="card__title">{{ app.name }}</h3>
          <p>{{ app.summary }}</p>
        </div>
      </article>
      {% endif %}
      {% endif %}
      {% endfor %}

      {# 8th tile: redirect to the full applications list — collage of the inside-only apps #}
      <a class="card app-card app-all" href="/applications/">
        {% image "src/assets/images/applications/all-apps-collage.jpg", "Collage of PVC sheets, WPC boards, roofing sheets, edge banding, footwear and paints", "(max-width: 768px) 100vw, 360px", { class: "app-all__bg" } %}
        <span class="app-all__scrim" aria-hidden="true"></span>
        <div class="app-all__content">
          <span class="app-all__icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
          <h3 class="app-all__title">See all applications</h3>
          <p>PVC sheets, edge banding &amp; more.</p>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ============ TECHNICAL ARTICLES ============ -->
<section class="section">
  <div class="container">
    <div class="section__head section__head--center">
      <span class="eyebrow">Knowledge Hub</span>
      <h2>Technical Articles</h2>
      <p class="lead">Practical guidance from four decades of PVC stabilization experience.</p>
    </div>
    {% set featured = collections.articles | first %}
    {% if featured %}
    <a class="article-feature" href="{{ featured.url }}">
      <div class="article-feature__media">
        {% image featured.data.image, featured.data.imageAlt, "(max-width: 768px) 100vw, 520px" %}
      </div>
      <div class="article-feature__body">
        <span class="article-feature__tag">Featured Article</span>
        <h3>{{ featured.data.title }}</h3>
        <p>{{ featured.data.description }}</p>
        <span class="card__link">Read the article →</span>
      </div>
    </a>
    {% endif %}
    <p class="section__cta"><a class="btn btn--ghost" href="/articles/">View all articles</a></p>
  </div>
</section>

<!-- ============ TECHNICAL SERVICES ============ -->
<section class="section section--alt" id="technical-services">
  <div class="container">
    <div class="section__head">
      <span class="eyebrow">What we do</span>
      <h2>Technical Services</h2>
      <p class="lead">Four decades of PVC additive know-how put to work on your process.</p>
    </div>
    <div class="expertise-grid">
      {% for e in home.services %}
      <article class="expertise-tile" id="service-{{ e.slug }}">
        <div class="expertise-tile__media">
          {% image e.image, e.title, "(max-width: 768px) 100vw, 300px" %}
        </div>
        <div class="expertise-tile__body">
          <h3 class="expertise-tile__title">{{ e.title }}</h3>
          <p>{{ e.text }}</p>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ============ CTA BAND ============ -->
<section class="cta-band">
  <div class="container cta-band__inner">
    <div>
      <h2>Ready to discuss your requirement?</h2>
      <p>Tell us your application, we'll recommend the right formulation.</p>
    </div>
    <div class="cta-band__actions">
      <a class="btn btn--accent btn--lg" href="{{ site.cta.quote.href }}">{{ site.cta.quote.label }}</a>
      <a class="btn btn--ghost btn--lg btn--on-dark" href="{{ site.contact.phoneHref }}">{{ site.cta.call.label }}</a>
    </div>
  </div>
</section>
