---
layout: layouts/base.njk
title: Contact & Request a Quote
description: Contact Stabplast Chemo Industries for PVC stabilizers, metallic stearates and lead compounds. Request a quote, technical data sheets or bulk pricing.
permalink: /contact/
---
{%- set canonical = (page.url | absoluteUrl(site.url)) -%}

<section class="page-hero">
  <div class="container page-hero__inner">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li class="sep" aria-hidden="true">/</li>
        <li aria-current="page">Contact</li>
      </ol>
    </nav>
    <span class="page-hero__eyebrow">Get in touch</span>
    <h1>Contact &amp; Request a Quote</h1>
    <p>Tell us your grade, application and volume — our team will respond with pricing, technical data sheets and lead times.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="contact-layout">

      {# ---- Quote / enquiry form ---- #}
      <div class="contact-form-wrap">
        <h2 class="contact-form__title">Request a quote</h2>
        <p class="contact-form__intro">Fields marked <span aria-hidden="true">*</span> are required. We typically reply within one business day.</p>

        {#
          NOTE: static form — no backend yet. Wire a submission service at deploy
          (Formspree / FormSubmit / Netlify Forms). Replace the action below with the
          real endpoint and remove data-form-endpoint.  [VERIFY] endpoint
        #}
        <form class="contact-form" method="POST" action="#" data-form-endpoint="[VERIFY] set Formspree/FormSubmit endpoint at deploy">
          {# Honeypot anti-spam field (bots fill it, humans don't). Formspree/FormSubmit honour _gotcha. #}
          <div class="form-hp" aria-hidden="true">
            <label>Leave this field empty<input type="text" name="_gotcha" tabindex="-1" autocomplete="off"></label>
          </div>

          <div class="form-row">
            <div class="field">
              <label for="cf-name">Full name <span class="req" aria-hidden="true">*</span></label>
              <input id="cf-name" name="name" type="text" autocomplete="name" required>
            </div>
            <div class="field">
              <label for="cf-company">Company <span class="req" aria-hidden="true">*</span></label>
              <input id="cf-company" name="company" type="text" autocomplete="organization" required>
            </div>
          </div>

          <div class="form-row">
            <div class="field">
              <label for="cf-email">Email <span class="req" aria-hidden="true">*</span></label>
              <input id="cf-email" name="email" type="email" autocomplete="email" required>
            </div>
            <div class="field">
              <label for="cf-phone">Phone</label>
              <input id="cf-phone" name="phone" type="tel" autocomplete="tel" inputmode="tel">
            </div>
          </div>

          <div class="form-row">
            <div class="field">
              <label for="cf-product">Product of interest</label>
              <select id="cf-product" name="product">
                <option value="">General enquiry</option>
                {% for cat in products.categories %}
                <optgroup label="{{ cat.name }}">
                  {% for p in products.items | byCategory(cat.slug) %}
                  <option value="{{ p.slug }}">{{ p.shortName }}</option>
                  {% endfor %}
                </optgroup>
                {% endfor %}
              </select>
            </div>
            <div class="field">
              <label for="cf-quantity">Estimated quantity</label>
              <input id="cf-quantity" name="quantity" type="text" placeholder="e.g. 5 MT / month">
            </div>
          </div>

          <div class="field">
            <label for="cf-message">Message <span class="req" aria-hidden="true">*</span></label>
            <textarea id="cf-message" name="message" rows="5" required placeholder="Tell us about your application, target specification and delivery location."></textarea>
          </div>

          <div class="field field--check">
            <label>
              <input type="checkbox" name="consent" value="yes" required>
              <span>I agree to be contacted about my enquiry. <span class="req" aria-hidden="true">*</span></span>
            </label>
          </div>

          <div class="contact-form__actions">
            <button class="btn btn--accent btn--lg" type="submit">Send enquiry</button>
            <p class="form-note">Prefer email? Write to <a href="{{ site.contact.emailHref }}">{{ site.contact.email }}</a>.</p>
          </div>
        </form>
      </div>

      {# ---- Contact details aside ---- #}
      <aside class="contact-aside" aria-label="Company contact details">
        <div class="contact-card">
          <h2 class="contact-card__title">{{ site.legalName }}</h2>
          <p class="contact-card__tagline">{{ site.tagline }}.</p>

          <ul class="contact-list">
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <span class="contact-list__label">Address</span>
                <address>
                  {{ site.contact.address.street }}<br>
                  {{ site.contact.address.locality }}, {{ site.contact.address.region }} {{ site.contact.address.postalCode }}<br>
                  {{ site.contact.address.country }}
                </address>
              </div>
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3-8.6A2 2 0 014.1 2H7a2 2 0 012 1.7c.1.9.4 1.8.7 2.7a2 2 0 01-.5 2.1L8.1 9.6a16 16 0 006 6l1.1-1.1a2 2 0 012.1-.5c.9.3 1.8.6 2.7.7A2 2 0 0122 16.9z"/></svg>
              <div>
                <span class="contact-list__label">Phone</span>
                <a href="{{ site.contact.phoneHref }}">{{ site.contact.phone }}</a>
              </div>
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="M22 6l-10 7L2 6"/></svg>
              <div>
                <span class="contact-list__label">Email</span>
                <a href="{{ site.contact.emailHref }}">{{ site.contact.email }}</a>
              </div>
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2" stroke-linecap="round"/></svg>
              <div>
                <span class="contact-list__label">Business hours</span>
                <span>{{ site.contact.hours }}</span>
              </div>
            </li>
          </ul>

          <div class="contact-card__cta">
            <a class="btn btn--primary" href="{{ site.contact.phoneHref }}">{{ site.cta.call.label }}</a>
            <a class="btn btn--ghost-dark" href="{{ site.contact.whatsappHref }}" rel="noopener">WhatsApp</a>
          </div>
        </div>

        {% if site.contact.mapEmbed %}
        <div class="contact-map">
          <iframe src="{{ site.contact.mapEmbed }}" title="{{ site.legalName }} location map" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
        {% endif %}
      </aside>

    </div>
  </div>
</section>

{# ---- Structured data (JSON-LD in body is valid per schema.org / Google) ---- #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": {{ "Contact & Request a Quote" | dump | safe }},
  "url": {{ canonical | dump | safe }},
  "about": {
    "@type": "Organization",
    "name": {{ site.legalName | dump | safe }},
    "url": {{ site.url | dump | safe }},
    "email": {{ site.contact.email | dump | safe }},
    "telephone": {{ site.contact.phone | dump | safe }},
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "sales",
      "telephone": {{ site.contact.phone | dump | safe }},
      "email": {{ site.contact.email | dump | safe }},
      "areaServed": {{ site.contact.address.country | dump | safe }},
      "availableLanguage": ["en"]
    }
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ ("/" | absoluteUrl(site.url)) | dump | safe }} },
    { "@type": "ListItem", "position": 2, "name": "Contact", "item": {{ canonical | dump | safe }} }
  ]
}
</script>
